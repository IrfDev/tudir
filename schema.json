{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TIUD_DATA",
  "type": "object",
  "required": ["defaultUrl", "axes", "columns", "blocks"],
  "properties": {
    "defaultUrl": { "type": "string", "format": "uri" },
    "axes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "color"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "color": {
            "type": "string",
            "pattern": "^#([0-9a-fA-F]{6})$"
          }
        },
        "additionalProperties": false
      }
    },
    "columns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "x", "y"],
        "properties": {
          "id": { "type": "string", "enum": ["A", "B", "C", "D"] },
          "title": { "type": "string" },
          "x": { "type": "number" },
          "y": { "type": "number" }
        },
        "additionalProperties": false
      }
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["n", "level", "axis", "axisIndex", "label"],
        "properties": {
          "n": { "type": "integer", "minimum": 1 },
          "level": { "type": "string", "enum": ["A", "B", "C", "D"] },
          "axis": { "type": "string" },
          "axisIndex": { "type": "integer", "minimum": 0, "maximum": 68 },
          "label": { "type": "string" },
          "url": { "type": "string", "format": "uri" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
